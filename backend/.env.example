# Database
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/dentaldb2"

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-to-a-random-64-byte-hex-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-byte-hex-string

# CORS origin (the domain your frontend is served from)
# For local dev: http://localhost:5173
# For production: https://your-domain.com
CORS_ORIGIN=http://localhost:5173

# Server port (default: 3001)
PORT=3001

# JWT token expiry (defaults used if omitted)
# JWT_ACCESS_EXPIRATION=500m
# JWT_REFRESH_EXPIRATION=7d

# Environment
# NODE_ENV=development