  receivedBy     Staff?  @relation("ReceiptReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  receivedByName String? // denormalized snapshot for printable receipts

  notes    String?
  metadata Json?

  // ── Account the money was received into + payment mode ───────────────
  accountId     String?
  account       Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  paymentMethod PaymentMethod?

  // ── Void audit trail ─────────────────────────────────────────────────
  status     ReceiptStatus @default(ACTIVE)
  voidedAt   DateTime?
  voidedBy   String?
  voidReason String?

  cashFlowEntries CashFlowEntry[]

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([paymentId])
  @@index([status])
  @@index([generatedAt])
  @@index([receivedById])
  @@map("receipts")
}

