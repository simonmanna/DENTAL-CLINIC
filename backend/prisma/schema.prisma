  amountReceived Decimal      @db.Decimal(10, 2)
  currencyCode   CurrencyCode @default(UGX)
  currency       String? // plain-string mirror of currencyCode for easier querying

  // ── Exchange-rate snapshot & base-currency equivalent ─────────────────
  exchangeRate       Decimal? @db.Decimal(10, 2)
  baseAmountReceived Decimal? @db.Decimal(10, 2)

  // ── Exact amount applied to invoice.amountPaid (invoice currency) ─────
  // Stored at creation for lossless reversal on void
  invoiceAmountApplied Decimal? @db.Decimal(10, 2)

  generatedAt DateTime @default(now())
  generatedBy String? // user id who created the receipt row (audit only)
  createdById String? // audit (C7) — auth user; mirrors generatedBy for new rows
  updatedById String? // audit (C7) — last auth user to mutate (e.g. void)

  // ── Who physically received the money (cashier) ──────────────────────
