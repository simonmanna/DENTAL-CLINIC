  itemName         String
  unit             String // Store as string for flexibility
  uom              UnitOfMeasure  @default(PIECES) // Standard UOM
  quantityOrdered  Decimal        @db.Decimal(12, 4) // High precision
  quantityReceived Decimal        @default(0) @db.Decimal(12, 4)
  unitCost         Decimal        @db.Decimal(10, 2)
  taxPercent       Decimal        @default(0) @db.Decimal(5, 2)
  discount         Decimal        @default(0) @db.Decimal(10, 2)
  total            Decimal        @db.Decimal(10, 2)
  batchNumber      String?
  expiryDate       DateTime?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  deliveryItems DeliveryItem[]

  @@map("purchase_order_items")
}

model Delivery {
  id              String         @id @default(cuid())
  deliveryCode    String         @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id])
  status          DeliveryStatus @default(PENDING)
  deliveryDate    DateTime       @default(now())
  receivedById    String?
  supplierRef     String?
  invoiceNumber   String?
  notes           String?
  attachments     String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items            DeliveryItem[]
  InventoryLedgers InventoryLedger[]

  @@index([purchaseOrderId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryItem {
  id                  String            @id @default(cuid())
  deliveryId          String
  delivery            Delivery          @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  itemType            String
  inventoryItemId     String
  inventoryItem       InventoryItem     @relation(fields: [inventoryItemId], references: [id])
  itemName            String
  unit                String
  uom                 UnitOfMeasure     @default(PIECES)
  quantityDelivered   Decimal           @db.Decimal(12, 4)
  quantityAccepted    Decimal           @db.Decimal(12, 4)
  quantityRejected    Decimal           @default(0) @db.Decimal(12, 4)
  quantityBilled      Float             @default(0) // For partial billing
  rejectionReason     String?
  unitCost            Decimal           @db.Decimal(10, 2)
  total               Decimal           @db.Decimal(10, 2)
  batchNumber         String?
  expiryDate          DateTime?
  notes               String?
  createdAt           DateTime          @default(now())

  @@map("delivery_items")
}

model InventoryLedger {
  id         String @id @default(cuid())
  ledgerCode String @unique // e.g. SL-20240001

  itemId     String
  item       InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  locationId String
  location   Location      @relation(fields: [locationId], references: [id], onDelete: Restrict)

  // Optional batch link (only for batch-tracked items)
  batchId String?
  batch   InventoryBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  type StockLedgerType

  // Stock levels at this location (NOT global item quantity)
  quantityBefore Float // location qty before this entry
  quantityChange Float // positive = IN, negative = OUT
  quantityAfter  Float // location qty after this entry

  unitCost   Decimal @default(0) @db.Decimal(10, 2)
  totalValue Decimal @default(0) @db.Decimal(10, 2) // abs(quantityChange) * unitCost

  // Source document (exactly one will be set)
  referenceType String? // "DELIVERY" | "ADJUSTMENT" | "WASTE" | "TRANSFER" | "VISIT" | "PHARMACY_SALE" | "PURCHASE_ORDER"
  referenceId   String? // FK-like to the source document

  notes              String?
  performedById      String?
  performedBy        User?   @relation("LedgerPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)
  performedByStaffId String?
  performedByStaff   Staff?  @relation("LedgerPerformedByStaff", fields: [performedByStaffId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  // Opposite of Delivery.InventoryLedgers
  delivery   Delivery? @relation(fields: [deliveryId], references: [id])
  deliveryId String?

  // Opposite of StockAdjustment.InventoryLedgers
  stockAdjustment   StockAdjustment? @relation(fields: [stockAdjustmentId], references: [id])
  stockAdjustmentId String?

  // Opposite of WasteRecord.InventoryLedgers
  wasteRecord   WasteRecord? @relation(fields: [wasteRecordId], references: [id])
  wasteRecordId String?

  stockTransfer   StockTransfer? @relation("TransferLedgerEntries", fields: [stockTransferId], references: [id])
  stockTransferId String?

  stockOut   StockOut? @relation(fields: [stockOutId], references: [id])
  stockOutId String?

  @@index([itemId])
  @@index([locationId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("inventory_ledger")
}

model StockAdjustment {
  id             String                @id @default(cuid())
  adjustmentCode String                @unique
  locationId     String
  location       Location              @relation(fields: [locationId], references: [id])
  reason         StockAdjustmentReason
  notes          String?
  status         String                @default("PENDING")
  approvedById   String?
  approvedAt     DateTime?
  performedById  String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  items            StockAdjustmentItem[]
  InventoryLedgers InventoryLedger[]

  @@index([status])
  @@index([locationId])
  @@map("stock_adjustments")
}

model StockAdjustmentItem {
  id                 String          @id @default(cuid())
  adjustmentId       String
  adjustment         StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  itemType           String?
  inventoryItemId    String
  inventoryItem      InventoryItem   @relation(fields: [inventoryItemId], references: [id])
  itemName           String
  unit               String
  quantitySystem     Float
  quantityActual     Float
  quantityDifference Float
  unitCost           Decimal         @default(0) @db.Decimal(10, 2)
  batchNumber        String?
  notes              String?
  createdAt          DateTime        @default(now())

  @@map("stock_adjustment_items")
}

model InventoryBatch {
  id          String        @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location      @relation(fields: [locationId], references: [id], onDelete: Restrict)
  batchNumber String? // null = no batch tracking for this item
  expiryDate  DateTime?
  quantity    Float         @default(0) // running balance for this specific batch
  unitCost    Decimal       @default(0) @db.Decimal(10, 2)
  receivedAt  DateTime      @default(now())
  isActive    Boolean       @default(true) // false = fully consumed / written off
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  ledgerEntries InventoryLedger[]

  @@unique([itemId, locationId, batchNumber]) // one row per batch per location
  @@index([itemId, locationId])
  @@index([expiryDate])
  @@index([isActive])
  @@map("inventory_batches")
}

model WasteRecord {
  id             String        @id @default(cuid())
  wasteCode      String        @unique
  locationId     String
  location       Location      @relation(fields: [locationId], references: [id])
  category       WasteCategory
  reportedById   String?
  approvedById   String?
  approvedAt     DateTime?
  totalValue     Decimal       @default(0) @db.Decimal(10, 2)
  notes          String?
  witnessName    String?
  disposalMethod String?
  disposalDate   DateTime?
  attachments    String[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items            WasteItem[]
  InventoryLedgers InventoryLedger[]

  @@index([locationId])
  @@index([category])
  @@map("waste_records")
}

model WasteItem {
  id              String        @id @default(cuid())
  wasteId         String
  waste           WasteRecord   @relation(fields: [wasteId], references: [id], onDelete: Cascade)
  itemType        String
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  itemName        String
  unit            String
  quantity        Float
  unitCost        Decimal       @default(0) @db.Decimal(10, 2)
  totalCost       Decimal       @default(0) @db.Decimal(10, 2)
  batchNumber     String?
  expiryDate      DateTime?
  reason          String?
  createdAt       DateTime      @default(now())

  @@map("waste_items")
}

model InventoryLocationStock {
  id          String        @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity    Float         @default(0) // sum of all active batches at this location
  minQuantity Float         @default(0)
  updatedAt   DateTime      @updatedAt

  @@unique([itemId, locationId]) // ← THE FIX
  @@map("inventory_location_stocks")
}

model LabOrder {
  id            String       @id @default(cuid())
  orderCode     String       @unique
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  visitId       String?
  visit         Visit?       @relation(fields: [visitId], references: [id])
  emrId         String?
  emr           EMRRecord?   @relation(fields: [emrId], references: [id])
  dentistId     String?
  dentist       Staff?       @relation(fields: [dentistId], references: [id])
  testName      String
  category      String
  instructions  String?
  urgency       String       @default("ROUTINE")
  status        String       @default("PENDING")
  resultFileUrl String?
  resultNotes   String?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("lab_orders")
}

model Expense {
  id          String @id @default(cuid())
  expenseCode String @unique

  // ── Category (dynamic, user-managed) ─────────────────────────────────
  // `categoryId` links to the live category; `categoryName` is a permanent
  // snapshot taken at creation so historical expenses keep their original
  // category label even if the category is later renamed/disabled/deleted.
  categoryId   String?
  category     ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryName String

  title       String
  description String?
  amount      Decimal       @db.Decimal(10, 2)
  expenseDate DateTime      @default(now())
  status      ExpenseStatus @default(APPROVED) // lifecycle status — defaults to APPROVED on creation

  // ── Payment progress (independent of lifecycle status) ───────────────
  paymentStatus ExpensePaymentStatus @default(UNPAID)
  amountPaid    Decimal              @default(0) @db.Decimal(10, 2)
  balance       Decimal              @default(0) @db.Decimal(10, 2)
  amountCredited Decimal             @default(0) @db.Decimal(10, 2) // sum of applied VendorCreditNote

  // ── NEW: optional supplier link ──────────────────────────────────────
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  // ── NEW: optional branch / location (for multi-clinic reporting) ────
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // ── NEW: how this expense will be / was settled ──────────────────────
  // CASH = immediate payment registered; CREDIT = pay later
  paymentType String @default("CREDIT") // "CASH" | "CREDIT"

  approvedById  String?
  approvedBy    User?     @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  approvalNotes String?

  paidAt DateTime?

  // ── Void tracking ────────────────────────────────────────────────────
  voidedAt   DateTime?
  voidedBy   String?
  voidReason String?

  // ── Soft-delete (defence-in-depth: NEVER hard-delete a financial row).
  //    A "delete" sets these fields; reports and drill-downs filter
  //    `deletedAt IS NULL` by default and surface deleted rows in audit.
  deletedAt     DateTime?
  deletedById   String?
  deletedBy     User?     @relation("ExpenseDeletedBy", fields: [deletedById], references: [id])
  deletedReason String?

  // ── Idempotency: client-supplied Idempotency-Key is also persisted on
  //    the row so two browser tabs with the same key cannot both create.
  idempotencyKey String? @unique

  createdById String
  createdBy   User     @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  version     Int      @default(0) // optimistic-lock counter
  attachments String[]
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments    Payment[]
  creditNotes VendorCreditNote[]

  @@index([status])
  @@index([paymentStatus])
  @@index([categoryId])
  @@index([expenseDate])
  @@index([createdAt])
  @@index([supplierId])
  @@index([locationId])
  @@index([deletedAt])
  @@map("expenses")
}

/// User-managed expense category. Replaces the former `ExpenseCategory` enum.
///   • `slug` is a stable UPPER_SNAKE handle (used for seeding & legacy mapping);
///     `name` is the user-facing label and is freely editable.
///   • `ledgerAccountId` is OPTIONAL — when set, expenses in this category post a
///     double-entry journal entry to that account; when null, the expense is
///     recorded but NOT posted to the general ledger (opt-in accounting).
///   • `isSystem` rows are seeded defaults: protected from deletion (disable
///     instead) but still fully editable (rename, re-map, disable).
model ExpenseCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String?
  icon        String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  isSystem    Boolean @default(false)

  // Optional GL link — present == post double-entry for this category.
  ledgerAccountId String?
  ledgerAccount   LedgerAccount? @relation(fields: [ledgerAccountId], references: [id], onDelete: SetNull)

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([ledgerAccountId])
  @@map("expense_categories")
}

/// Generic, append-only audit log. One row per state change.
///   • action      = CREATE | UPDATE | DELETE | VOID | CANCEL | RESTORE | EXECUTE | …
///   • module      = high-level area, e.g. "TREATMENT_PLANS", "BILLING"
///   • entityType  = the model name, e.g. "ProcedureSession", "TreatmentProcedure"
///   • recordId    = the entity's primary key (kept on UPDATE/DELETE — never FK)
///   • oldData/newData = full or partial snapshot before/after the change
///   • reason      = user-supplied free-text justification (required for void/edit)
///   • userId/userName = who made the change (userName denormalised in case the
///     user is later deleted)
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  userName   String?
  action     String
  module     String
  entityType String?
  recordId   String?
  oldData    Json?
  newData    Json?
  reason     String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, recordId])
  @@index([module, action])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Atomic, gap-free-per-tenant monotonic sequence generator.
/// Replaces count()+1 number generation. Use SequenceService.next(key).
/// `tenantId` defaults to "DEFAULT" for single-tenant installs; switch to
/// real clinic/tenant id when multi-tenancy lands.
model NumberSequence {
  id           String   @id @default(cuid())
  tenantId     String   @default("DEFAULT")
  key          String // e.g. "INVOICE", "RECEIPT", "PAYMENT"
  currentValue BigInt   @default(0)
  prefix       String? // optional override for code formatting; falls back to caller-supplied
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([tenantId, key])
  @@map("number_sequences")
}

/// Per-(prefix, year) monotonic counter backing the `generate_document_number`
/// PostgreSQL function. One row per document type per calendar year, so numbering
/// resets every year (TP-26-9999 → TP-27-0001). The function uses
/// INSERT ... ON CONFLICT DO UPDATE ... RETURNING, which row-locks the conflicting
/// row, making increments atomic and concurrency-safe (no COUNT(*), no race).
/// Numbers are never reused after deletion — the counter only ever increments.
model DocumentCounter {
  prefix       String
  year         Int
  currentValue BigInt   @default(0) @map("current_value")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([prefix, year])
  @@map("document_counters")
}

/// Request-deduplication store for idempotent write endpoints. The client sends
/// an `Idempotency-Key` header; the first request stores its response here and
/// retries with the same key replay that stored response instead of re-running
/// the operation. `key` is the PK, so a concurrent duplicate hitting the unique
/// constraint inside its transaction rolls back (no duplicate side effects).
/// Rows past `expiresAt` can be pruned by a periodic job.
model IdempotencyKey {
  key       String   @id
  scope     String // e.g. "EXECUTE_SESSION"
  response  Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
  @@map("idempotency_keys")
}

