  COMPLETED
  FAILED
  REFUNDED
  VOIDED
}

// BALANCE / billing-workflow state for things that carry an outstanding amount
// (visits, visit procedures, treatment procedures, purchase orders). Distinct
// from PaymentStatus, which is only ever the state of a Payment transaction.
// OPEN = created, not yet invoiced; INVOICED = billed, awaiting collection.
// (The legacy duplicate PARTIAL was folded into PARTIALLY_PAID.)
enum BalanceStatus {
  OPEN
  INVOICED
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  WRITTEN_OFF
}

