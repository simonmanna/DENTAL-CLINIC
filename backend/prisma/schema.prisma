  @@index([name])
  @@map("suppliers")
}

model InventoryCategory {
  id          String              @id @default(cuid())
  name        String              @unique
  code        String?             @unique // Short code for API/UI (e.g., "CONS", "INST")
  description String?
  color       String? // Hex color for UI badges (e.g., "#4A90D9")
  icon        String? // Lucide icon name for UI
  parentId    String? // For hierarchical categories
  parent      InventoryCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    InventoryCategory[] @relation("CategoryHierarchy")

  isActive  Boolean @default(true)
  sortOrder Int     @default(0) // For custom ordering in UI

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  // Relations
  inventoryItems InventoryItem[]

  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("inventory_categories")
}

enum InventoryType {
  MEDICINE
  CONSUMABLE
  EQUIPMENT
}

enum StockTransferStatus {
  DRAFT
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model InventoryItem {
  id            String        @id @default(cuid())
  itemCode      String        @unique
