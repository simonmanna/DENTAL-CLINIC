  description String

  // ── Source document reference ─────────────────────────────────────────
  sourceType String? // "TREATMENT_PROCEDURE" | "PROCEDURE_SESSION" | "VISIT_PROCEDURE"
  sourceId   String?

  // ── Core financials (Decimal for accounting precision) ────────────────
  quantity       Int     @default(1)
  pricePerUnit   Decimal @default(0) @db.Decimal(12, 2)
