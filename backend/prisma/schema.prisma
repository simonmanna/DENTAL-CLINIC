model TreatmentProcedure {
  id              String        @id @default(cuid())
  treatmentPlanId String
  treatmentPlan   TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  procedureId     String
  procedure       Procedure     @relation(fields: [procedureId], references: [id])

  // ── Clinical context ──────────────────────────────────────────────────
  notes            String?
  scheduledDate    DateTime?
  completedAt      DateTime?
  performedDate    DateTime?
  performedNotes   String?
  actualInputsUsed Json? // ActualInput[] — recorded at performance time
  status           TreatmentStatus @default(PLANNED)
  sequence         Int             @default(0)
  visitGroup       Int             @default(1)

  // ── Billing context (snapshot of WHY quantity = N) ────────────────────
  // e.g. { "teeth": [11,12,13], "arches": 1, "sessions": 3 }
  billingContext Json?

  // ── Pricing snapshot (taken at time of adding to plan) ───────────────
  pricingModel PricingModel @default(FIXED)
  billingUnit  BillingUnit?
  quantity     Int          @default(1) // # of billing units

  pricePerUnit   Decimal @default(0) @db.Decimal(12, 2) // selling price per unit
  costPerUnit    Decimal @default(0) @db.Decimal(12, 2) // internal cost per unit
  subtotalPrice  Decimal @default(0) @db.Decimal(12, 2) // pricePerUnit × quantity
  subtotalCost   Decimal @default(0) @db.Decimal(12, 2) // costPerUnit × quantity
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal @default(0) @db.Decimal(12, 2)
  totalPrice     Decimal @default(0) @db.Decimal(12, 2) // final after discount/tax

  // ── Multi-currency ────────────────────────────────────────────────────
  currency     String   @default("UGX") // procedure's pricing currency
  exchangeRate Decimal? @db.Decimal(10, 4) // rate used at time of adding
  baseCurrency String   @default("UGX") // system reporting currency
  baseAmount   Decimal  @default(0) @db.Decimal(12, 2) // totalPrice in baseCurrency

  // ── Payment tracking ──────────────────────────────────────────────────
  amountPaid    Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus BalanceStatus @default(OPEN)

  // ── Session config ────────────────────────────────────────────────────
  sessionType  SessionType @default(SINGLE)
  sessionCount Int         @default(1)
  billingType  BillingType @default(PAY_FULL)

  // ── Ledger link ───────────────────────────────────────────────────────
  ledgerEntryId String?
  ledgerEntry   LedgerEntry?        @relation(fields: [ledgerEntryId], references: [id])
  ledgerStatus  SessionLedgerStatus @default(PENDING)

  sessions ProcedureSession[]

  targets           ProcedureTarget[]
  chartEntries      ChartEntry[]
  phase             String?
  plannedVisitIndex Int? // replaces visitGroup (gradual migration)

  conditionLinks ConditionProcedureLink[]

  resolvedConditions PatientCondition[] @relation("ResolvedByProcedure")

  providerId String?
  provider   Staff?  @relation("TreatmentProcedureProvider", fields: [providerId], references: [id], onDelete: SetNull)

  invoiceItems InvoiceItem[] @relation("InvoiceItemTP")

  // ── Audit reasons (denormalised for quick display; full history in AuditLog) ─
  cancellationReason String?
  lastEditReason     String?

  // ── Soft delete ──────────────────────────────────────────────────────────
  // Clinical records are never hard-deleted. A "delete" stamps deletedAt,
  // voids linked invoice items, supersedes chart entries, and preserves the
  // full audit trail.
  deletedAt     DateTime?
  deletedById   String?
  deletedReason String?

  // ── Optimistic concurrency control (H2) ───────────────────────────────────
  // Bumped on every mutation; clients pass the value they last read as
  // `expectedVersion` so a concurrent edit is rejected (409) instead of silently
  // overwriting another clinician's change.
  version Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treatmentPlanId, visitGroup])
  @@index([procedureId])
  @@index([status])
  @@index([paymentStatus])
  @@map("treatment_procedures")
}

model ProcedureSession {
  id                   String             @id @default(cuid())
  treatmentProcedureId String
  treatmentProcedure   TreatmentProcedure @relation(fields: [treatmentProcedureId], references: [id], onDelete: SetNull)

  // Add these fields
  visitId String?
  visit   Visit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)

  // ── Clinical identity ─────────────────────────────────────────────────
  visitGroup    Int     @default(1)
  sessionNumber Int // 1, 2, 3 …
  sessionLabel  String? // "Root Canal – Session 2 of 3"

  // ── Clinical tracking ─────────────────────────────────────────────────
  status           SessionStatus  @default(PENDING)
  performedDate    DateTime?
  performedNotes   String?
  actualInputsUsed Json? // ActualInput[]
  surfaces         ToothSurface[] // ← was String[]; now DB-validated like everywhere else

  // ── Optional billing (only populated when billingType = PAY_PARTIALLY) ─
  // For PAY_FULL: leave null — the parent TreatmentProcedure carries the price
  sessionCost  Decimal? @db.Decimal(12, 2)
  sessionPrice Decimal? @db.Decimal(12, 2)

  // ── Ledger link ───────────────────────────────────────────────────────
  ledgerEntryId String?
  ledgerEntry   LedgerEntry?        @relation(fields: [ledgerEntryId], references: [id])
  ledgerStatus  SessionLedgerStatus @default(PENDING)

  targets      ProcedureTarget[]
  chartEntries ChartEntry[]
  providerId   String?
  startedAt    DateTime?
  endedAt      DateTime?

  progressReportLinks ProgressReportProcedure[]

  phase   String? // 'CLEANING' | 'SHAPING' | 'FILLING' etc — stored as string for flexibility
  outcome String? // 'PARTIAL' | 'COMPLETED'
  isFinal Boolean @default(false) // marks this as the session that closes the procedure

  // providerId already exists — add the relation:
  provider Staff? @relation("SessionProvider", fields: [providerId], references: [id], onDelete: SetNull)

  edits          ProcedureSessionEdit[]
  imagingRecords ImagingRecord[]

  // ── Soft delete (status = VOIDED, deletedReason = void reason) ────────
  // Clinical records are never hard-deleted. A "void" sets status=VOIDED,
  // stamps deletedAt/deletedById, captures deletedReason, and reverses
  // every side effect (chart entries, ledger, imaging, progress reports).
  deletedAt     DateTime?
  deletedById   String?
  deletedReason String?

  // Latest edit reason, denormalised for quick display. Full diff history
  // lives in ProcedureSessionEdit + AuditLog.
  lastEditReason String?

  // ── Optimistic concurrency control (H2) — see TreatmentProcedure.version ──
  version Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NOTE: uniqueness of (treatmentProcedureId, sessionNumber) over ACTIVE
  // (deletedAt IS NULL) rows is enforced by the partial unique index
  // procedure_sessions_active_session_number_unique — see migration
  // 20260710000001_partial_unique_indexes_and_checks. Prisma's @@unique
  // cannot express partial predicates.
  @@index([treatmentProcedureId])
  @@index([visitGroup])
  @@index([status])
  @@index([visitId])
  @@index([deletedAt])
  @@map("procedure_sessions")
}

model TreatmentAttachment {
  id              String        @id @default(cuid())
  treatmentPlanId String
  treatmentPlan   TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  name            String
  fileUrl         String
  fileType        String
  uploadedAt      DateTime      @default(now())

  @@map("treatment_attachments")
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  patientId      String
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointmentId  String?
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])
  visitId        String?
  visit          Visit?        @relation(fields: [visitId], references: [id])
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @default(0) @db.Decimal(10, 2)
  discountType   String?
  discountValue  Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  taxPercent     Decimal       @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @default(0) @db.Decimal(10, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(10, 2)
  balance        Decimal       @default(0) @db.Decimal(10, 2)
  notes          String?
  dueDate        DateTime?
  issuedAt       DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Currency fields
  currency     String  @default("UGX")
  exchangeRate Decimal @default(1) @db.Decimal(10, 4)
  baseCurrency String  @default("UGX")

  baseSubtotal       Decimal @default(0) @db.Decimal(10, 2)
  baseDiscountAmount Decimal @default(0) @db.Decimal(10, 2)
  baseTaxAmount      Decimal @default(0) @db.Decimal(10, 2)
  baseTotal          Decimal @default(0) @db.Decimal(10, 2)
  baseAmountPaid     Decimal @default(0) @db.Decimal(10, 2)
  baseBalance        Decimal @default(0) @db.Decimal(10, 2)

  // ── Lifecycle ─────────────────────────────────────────────────────
  activatedAt            DateTime? // set when status moves DRAFT → POSTED
  // Spec wording: "User's initial deposit amount & currency to pay is
  // registered in the draft invoice as initialCurrency & initialReceipt".
  // Implementation note: the schema uses the more verbose
  // `initialPaymentAmount` / `initialPaymentCurrency` (these are the
  // current DB field names). They are semantically identical to the
  // spec's `initialReceipt` / `initialCurrency` — the deposit amount
  // is kept in the deposit currency, NOT converted to the invoice
  // currency. See `backend/src/billing/invoice-lifecycle.service.ts`
  // for the write paths and the Adding Procedure spec.
  initialPaymentAmount   Decimal?  @db.Decimal(10, 2) // deposit amount as the patient agreed (in initialPaymentCurrency) — a.k.a. spec's `initialReceipt`
  initialPaymentCurrency String? // currency the patient agreed to pay the deposit in (e.g. "USD") — a.k.a. spec's `initialCurrency`

  // ── Payment status & terms ───────────────────────────────────────
  paymentStatus InvoicePaymentStatus @default(UNPAID)
  paymentTerms  String               @default("CASH")

  // ── Void audit trail ─────────────────────────────────────────────
  voidedAt   DateTime?
  voidedBy   String?
  voidReason String?

  // ── Soft delete (B6) — invoices are NEVER hard-deleted ──────────
  deletedAt     DateTime?
  deletedById   String?
  deletedReason String?

  // ── Optimistic-concurrency token (H6) ──────────────────────────────
  // Bumped on every mutation by the service layer's atomic UPDATE
  // statements (recalcInvoiceAtomicTx / voidInvoice / addPayment).
  // Used as the optimistic-lock guard: `WHERE version = $expected`
  // detects a concurrent edit and surfaces a 409 instead of a silent
  // lost update on the invoice's stored totals. Matches the proven
  // `version` pattern on treatment_procedures / chart_entries /
  // expenses / purchase_orders. Adding a column is non-breaking; the
  // DEFAULT 0 backfills all existing rows in one statement.
  version Int @default(0)

  // ── Audit columns (C7) ──────────────────────────────────────────
  createdById String?
  updatedById String?

  treatmentPlanId String?
  treatmentPlan   TreatmentPlan? @relation("TreatmentPlanInvoices", fields: [treatmentPlanId], references: [id], onDelete: SetNull)

  items        InvoiceItem[]
  payments     Payment[]
  receipts     Receipt[]
  pharmacySale PharmacySale?

  @@index([patientId, status])
  @@index([visitId])
  @@index([treatmentPlanId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([paidAt])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("invoices")
}

model InvoiceItem {
  id            String       @id @default(cuid())
  invoiceId     String
  invoice       Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  procedureId   String?
  procedure     Procedure?   @relation(fields: [procedureId], references: [id])
  description   String
  quantity      Int          @default(1)
  unitPrice     Decimal      @db.Decimal(10, 2)
  discount      Decimal      @default(0) @db.Decimal(10, 2)
  total         Decimal      @db.Decimal(10, 2)
  toothNumbers  Int[]
  createdAt     DateTime     @default(now())
  ledgerEntryId String?
  ledgerEntry   LedgerEntry? @relation(fields: [ledgerEntryId], references: [id])

  originalCurrency  String?
  originalUnitPrice Decimal? @db.Decimal(10, 2)
  originalTotal     Decimal? @db.Decimal(10, 2)
  exchangeRate      Decimal  @default(1) @db.Decimal(10, 4)

  // ── New fields for refactored billing ────────────────────────────
  itemType             InvoiceItemType     @default(MANUAL)
  treatmentProcedureId String?
  treatmentProcedure   TreatmentProcedure? @relation("InvoiceItemTP", fields: [treatmentProcedureId], references: [id], onDelete: SetNull)
  status               InvoiceItemStatus   @default(ACTIVE)

  @@index([invoiceId])
  @@index([treatmentProcedureId])
  @@map("invoice_items")
}

model Payment {
  id          String            @id @default(cuid())
  paymentCode String            @unique // was missing on old Payment
  type        PaymentType
  direction   CashFlowDirection // IN | OUT

  // ── Source document (exactly one populated) ──────────────────────────
  // NOTE: onDelete: Restrict — payments must never be cascaded away by deleting
  // the source document. Invoices are soft-deleted; payments are voided in place.
  invoiceId       String?
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  expenseId       String?
  expense         Expense?       @relation(fields: [expenseId], references: [id], onDelete: Restrict)

  // ── Core fields ───────────────────────────────────────────────────────
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(COMPLETED)
  reference     String?
  transactionId String?
  bankName      String? // bank transfers / cheques
  chequeNumber  String?
  notes         String?

  // ── Parties ───────────────────────────────────────────────────────────
  receivedBy   String? // populated for INVOICE_RECEIPT (cashier name)
  recordedById String? // user who created this payment record
  createdById  String? // audit (C7) — auth user who created this row
  updatedById  String? // audit (C7) — last auth user to mutate this row

  // ── Currency ──────────────────────────────────────────────────────────
  currency     String  @default("UGX")
  exchangeRate Decimal @default(1) @db.Decimal(10, 4)
  baseAmount   Decimal @default(0) @db.Decimal(10, 2)

  // ── Void tracking ─────────────────────────────────────────────────────
  voidedAt   DateTime?
  voidedBy   String?
  voidReason String?

  paidAt    DateTime @default(now())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    receipts        Receipt[]
    cashFlowEntries CashFlowEntry[]
    creditNote      VendorCreditNote? @relation("VendorCreditNotePayment")

    @@index([type])
    @@index([direction])
    @@index([invoiceId])
    @@index([purchaseOrderId])
    @@index([expenseId])
    @@index([status])
    @@index([paidAt])
    @@map("payments")
  }

  /// Vendor credit note — supplier-issued credit against a PurchaseOrder or an
  /// Expense (e.g. returned defective goods, negotiated rebate, post-billing
  /// discount). Mirrors Invoice/CreditNote symmetry in patient billing but on
  /// the procurement side. Applied credits reduce the source document's
  /// outstanding balance (and post `DR AP · CR Inventory/Cash` on GL).
  ///
  /// Lifecycle:
  ///   DRAFT → APPROVED → APPLIED  (terminal once applied; voiding is a reversal
  ///                               by posting an opposite Payment of type CREDIT_NOTE_REVERSAL).
  ///
  /// `creditNoteNumber` is generated via DocumentNumberService ('VCN' prefix).
  model VendorCreditNote {
    id              String                  @id @default(cuid())
    creditNoteNumber String                 @unique

    supplierId String
    supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

    // Optional link to the PO or Expense this credit is reducing. Exactly one
    // is populated; the other is null. Enforced at service-layer because
    // Prisma doesn't support multi-column XOR constraints cleanly.
    purchaseOrderId String?
    purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
    expenseId       String?
    expense         Expense?       @relation(fields: [expenseId], references: [id], onDelete: SetNull)

    amount      Decimal                 @db.Decimal(12, 2)
    currency    String                  @default("UGX")
    exchangeRate Decimal                @default(1) @db.Decimal(10, 4)
    baseAmount  Decimal                 @db.Decimal(12, 2)

    reason        String // free text: "Defective shipment", "Volume rebate", etc.
    vendorRef     String? // supplier's reference number on the credit memo
    documentDate  DateTime               @default(now())
    status        VendorCreditNoteStatus @default(DRAFT)

    approvedById String?
    approvedAt   DateTime?
    appliedAt    DateTime?
    voidedAt     DateTime?
    voidReason   String?

    // The resulting Payment that physically moves the credit onto the books.
    // Created on APPLY via PaymentsService.createCreditNotePayment; null while
    // the credit note is in DRAFT/APPROVED.
    paymentId String? @unique
    payment   Payment? @relation("VendorCreditNotePayment", fields: [paymentId], references: [id], onDelete: SetNull)

    // Audit actors (denormalised on AuditLog rows; FKs for drill-down).
    createdById String
    updatedById String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([supplierId])
    @@index([status])
    @@index([documentDate])
    @@index([purchaseOrderId])
    @@index([expenseId])
    @@map("vendor_credit_notes")
  }

  enum VendorCreditNoteStatus {
    DRAFT
    APPROVED
    APPLIED
    VOIDED
  }

model EMRRecord {
