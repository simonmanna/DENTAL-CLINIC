/// DEPRECATED — legacy parallel tooth-state system. The source of truth for the
/// dental chart is the ChartEntry model (+ TreatmentProcedure / PatientCondition).
/// This model is still written by visit.service (legacy tooth-status update) and
/// read by clinical-report (tooth-status distribution); migrate those to ChartEntry
/// before dropping these tables. The orphaned /dental-chart API was removed
/// 2026-06-12. Do not add new readers/writers.
model Procedure {
  id   String  @id @default(cuid())
  code String? @unique
  name String

  // ── Category (proper FK instead of bare String) ───────────────────────
  categoryId String
  category   ProcedureCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  description String?

  // ── Internal cost (what it costs the clinic) ─────────────────────────
  baseCost Decimal @default(0) @db.Decimal(12, 2)

  // ── Default selling price ─────────────────────────────────────────────
  basePrice Decimal @default(0) @db.Decimal(12, 2)

  // ── Pricing logic: HOW to calculate the total ─────────────────────────
  pricingModel PricingModel @default(FIXED)
  billingUnit  BillingUnit? // Explicit unit label (TOOTH, ARCH …)

  // ── Price guardrails ──────────────────────────────────────────────────
  priceRangeMin Decimal? @db.Decimal(12, 2)
  priceRangeMax Decimal? @db.Decimal(12, 2)

  // ── Currency the procedure is defined in ─────────────────────────────
  currency String @default("UGX")

  // ── Revenue mapping (per-procedure override) ──────────────────────────
  // Optional link to the GL revenue (INCOME) account this procedure posts to.
  // Resolution order at posting time: this field → category.revenueAccountId
  // → system default TREATMENT_REVENUE. See InvoiceLifecycleService.
  revenueAccountId String?
  revenueAccount   LedgerAccount? @relation("ProcedureRevenueAccount", fields: [revenueAccountId], references: [id], onDelete: SetNull)

  // Just this — no @relation attributes needed:
  patientConditions PatientCondition[]

  defaultDuration Int      @default(30)
  requiresXray    Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inputs              ProcedureInventoryInput[]
  treatmentProcedures TreatmentProcedure[]
  visitProcedures     VisitProcedure[]
  invoiceItems        InvoiceItem[]
  imagingRecords      ImagingRecord[]          @relation("ProcedureImaging")

  @@index([categoryId])
  @@index([isActive])
  @@index([pricingModel])
  @@map("procedures")
}

model TreatmentPlan {
