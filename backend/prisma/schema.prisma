  category             InventoryCategory?             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  drug                 Drug?
  purchaseOrderItems   PurchaseOrderItem[]
  locationStocks       InventoryLocationStock[]
  procedureInputs      ProcedureInventoryInput[]
  visitProcedureUsages VisitProcedureInventoryUsage[]
  deliveryItems        DeliveryItem[]
  adjustmentItems      StockAdjustmentItem[]
  wasteItems           WasteItem[]
  batches              InventoryBatch[]
