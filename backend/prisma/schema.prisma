// ALL Models

// ── NEW MODEL: ProcedureTarget ────────────────────────────────────────────────
// Normalised tooth + surface ownership.
// Replaces toothNumbers[] and surfaces[] arrays on TreatmentProcedure.

model ProcedureTarget {
  id String @id @default(cuid())

  treatmentProcedureId String?
  treatmentProcedure   TreatmentProcedure? @relation(fields: [treatmentProcedureId], references: [id], onDelete: Cascade)

  procedureSessionId String?
  procedureSession   ProcedureSession? @relation(fields: [procedureSessionId], references: [id], onDelete: Cascade)

  toothNumber Int?
  surfaces    ToothSurface[]
  unitIndex   Int? // For multi-unit pricing (e.g. bracket index)

  toothNotation ToothNotation @default(FDI) // ← NEW

  createdAt DateTime @default(now())

  @@index([treatmentProcedureId])
  @@index([procedureSessionId])
}

model ProcedureCategory {
  id          String              @id @default(cuid())
  name        String              @unique
  code        String?             @unique
  description String?
  color       String? // Hex color for UI (e.g. "#4A90D9")
  icon        String? // Icon identifier for UI
  parentId    String?
  parent      ProcedureCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProcedureCategory[] @relation("CategoryHierarchy")
  isActive    Boolean             @default(true)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // ── Revenue mapping (category-level default) ──────────────────────────
  // Optional link to the GL revenue (INCOME) account that procedures in this
  // category post to. A procedure's own `revenueAccountId` overrides this;
  // when both are null the posting engine falls back to TREATMENT_REVENUE.
  revenueAccountId String?
  revenueAccount   LedgerAccount? @relation("ProcedureCategoryRevenueAccount", fields: [revenueAccountId], references: [id], onDelete: SetNull)

  procedures Procedure[]

  @@index([parentId])
  @@index([isActive])
  @@index([revenueAccountId])
  @@map("procedure_categories")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  role         UserRole  @default(RECEPTIONIST)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  staff            Staff?
    auditLogs        AuditLog[]
    expensesCreated  Expense[]         @relation("ExpenseCreatedBy")
    expensesApproved Expense[]         @relation("ExpenseApprovedBy")
    expensesDeleted  Expense[]         @relation("ExpenseDeletedBy")
    suppliersCreated Supplier[]        @relation("SupplierCreatedBy")
    suppliersUpdated Supplier[]        @relation("SupplierUpdatedBy")
  ledgerEntries    InventoryLedger[] @relation("LedgerPerformedBy")
stockMovements      StockMovement[]           @relation("StockMovementCreatedBy")
  stockTransfers      StockTransfer[]
  treatmentConsumptions TreatmentConsumption[]
  notifications           Notification[]           @relation("UserNotifications")
  notificationsTriggered  Notification[]           @relation("NotificationActor")
  notificationPreferences NotificationPreference[] @relation("NotificationPreferences")

  @@map("users")
}

model Staff {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffCode      String   @unique @default(cuid())
  firstName      String
  lastName       String
  phone          String?
  avatar         String?
  specialization String?
  licenseNumber  String?
  qualification  String?
  bio            String?
  isAvailable    Boolean  @default(true)
  joiningDate    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  progressReports  ProgressReport[]
  schedules        StaffSchedule[]
  appointments     Appointment[]
  treatmentPlans   TreatmentPlan[]
  emrRecords       EMRRecord[]
  prescriptions    Prescription[]
  imagingRecords   ImagingRecord[]
  performanceNotes PerformanceNote[]
  visits           Visit[]
  labOrders        LabOrder[]
  ledgerEntries    InventoryLedger[] @relation("LedgerPerformedByStaff")
  assignedAssets   FixedAsset[]      @relation("AssetAssignedTo")

  // In Staff model — add the back-relations:
  chartEntriesProvided        ChartEntry[]         @relation("ChartEntryProvider")
  patientConditionsProvided   PatientCondition[]   @relation("PatientConditionProvider")
  treatmentProceduresProvided TreatmentProcedure[] @relation("TreatmentProcedureProvider")
  procedureSessions           ProcedureSession[]   @relation("SessionProvider")
  receiptsReceived            Receipt[]            @relation("ReceiptReceivedBy")

  @@map("staff")
}

model StaffSchedule {
  id        String   @id @default(cuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  startTime String
  endTime   String
  isWorking Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("staff_schedules")
}

model PerformanceNote {
  id        String   @id @default(cuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  period    String
  notes     String
  rating    Int?
  createdAt DateTime @default(now())

  @@map("performance_notes")
}

model StockMovement {
  id             String            @id @default(cuid())
  type           StockMovementType
  itemType       String
  itemId         String
  itemName       String
  quantity       Float
  batchNumber    String?
  fromLocationId String?
  fromLocation   Location?         @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocationId   String
  toLocation     Location          @relation("ToLocation", fields: [toLocationId], references: [id])
  reason         String?
  reference      String?
  performedById  String?
  performedBy    User?             @relation("StockMovementCreatedBy", fields: [performedById], references: [id])
  notes          String?
  createdAt      DateTime          @default(now())

  @@index([itemType, itemId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@map("stock_movements")
}

model Location {
  id        String       @id @default(cuid())
  name      String
  type      LocationType
  address   String?
  phone     String?
  email     String?
  isActive  Boolean      @default(true)
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Hierarchical fields - ADD THESE
  parentId  String?
  parent    Location?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Location[] @relation("LocationHierarchy")
  path      String     @default("") // Materialized path: "/parentId/childId/"
  level     Int        @default(0) // 0 = root, 1 = child, etc.
  sortOrder Int        @default(0) // For ordering siblings

  inventoryStocks    InventoryLocationStock[]
  stockMovementsFrom StockMovement[]          @relation("FromLocation")
  stockMovementsTo   StockMovement[]          @relation("ToLocation")
  pharmacySales      PharmacySale[]

  procedureInputs      ProcedureInventoryInput[]
  visitProcedureUsages VisitProcedureInventoryUsage[]

  // These fields were outside the model block!
  purchaseOrders   PurchaseOrder[]
  deliveries       Delivery[]
  stockAdjustments StockAdjustment[]
  wasteRecords     WasteRecord[]
  fixedAssets      FixedAsset[]
  batches          InventoryBatch[]
  ledgerEntries    InventoryLedger[]

  transfersFrom StockTransfer[] @relation("TransferFrom")
    transfersTo   StockTransfer[] @relation("TransferTo")

    stockOuts StockOut[]

    // Back-relations for the expense/payment/credit-note audit/segmentation work.
    expenses   Expense[]

    @@map("locations")
  }

model Patient {
  id                 String    @id @default(cuid())
  patientCode        String    @unique
  firstName          String
  lastName           String
  dateOfBirth        DateTime?
  gender             Gender?
  phone              String?
  alternatePhone     String?
  email              String?
  address            String?
  city               String?
  country            String    @default("Uganda")
  occupation         String?
  previousCardNumber String?
  avatar             String?
  isActive           Boolean   @default(true)
  registeredAt       DateTime  @default(now())
