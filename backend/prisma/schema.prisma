}

enum ChartPresenceEffect {
  NONE // normal condition (caries, pulpitis…) — tooth still present
  EXTRACTED // acquired loss — ghost crown + X, no root, restorable
  CONGENITAL // never developed — faint dashed, no root
  UNERUPTED // exists but not erupted/impacted — dashed, offset
  SUPERNUMERARY // extra tooth — drawn but flagged
  RETAINED_ROOT // crown lost, root retained in situ (K08.3) — roots + stump
}

model ChartEntry {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  visitId String?
  visit   Visit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)

  // What tooth & surfaces this entry targets
  toothNumber   Int?
  toothNotation ToothNotation  @default(FDI) // ← NEW
  surfaces      ToothSurface[]

  // What kind of clinical event this is
  type   ChartEntryType
  status ChartEntryStatus @default(ACTIVE)

  // Human-readable label shown on the chart (e.g. "Caries", "PFM Crown")
  label String

  // Structured codes (optional but good for reporting)
  conditionCode String? // ICD-10 code  e.g. "K02.9"
  procedureCode String? // CDT code      e.g. "D2740"

  // Optional links to the data that created this entry
  treatmentProcedureId String?
  treatmentProcedure   TreatmentProcedure? @relation(fields: [treatmentProcedureId], references: [id], onDelete: SetNull)

  procedureSessionId String?
  procedureSession   ProcedureSession? @relation(fields: [procedureSessionId], references: [id], onDelete: SetNull)

  treatmentPlans     TreatmentPlan[]
  conditionId        String?
  condition          Condition?        @relation(fields: [conditionId], references: [id], onDelete: SetNull)
  patientConditionId String?
  patientCondition   PatientCondition? @relation(fields: [patientConditionId], references: [id], onDelete: SetNull)

  notes          String?
  diagnosedAt    DateTime?
  conditionStatus PatientConditionStatus?
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // M-2: optimistic-lock token. Mutations (updateEntry / voidEntry /
  // supersedeEntry / updateCondition) bump it and may be gated on an
  // expectedVersion so two concurrent edits can't silently overwrite each
  // other. Matches the `version` pattern on treatment_procedures / sessions.
  version Int @default(0)

  providerId String?
  provider   Staff?  @relation("ChartEntryProvider", fields: [providerId], references: [id], onDelete: SetNull)

  imagingRecords ImagingRecord[] @relation("ChartEntryImaging")

  @@index([patientId])
  @@index([patientId, toothNumber])
  @@index([visitId])
  // D2: the condition-lifecycle updateMany filters by patientConditionId /
  // conditionId, and getPatientEntries filters by (patientId, type, status).
  // These back those hot paths instead of table-scanning.
  @@index([patientConditionId])
  @@index([conditionId])
  @@index([patientId, type, status])
}

