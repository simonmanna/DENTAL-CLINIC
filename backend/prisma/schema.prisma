model ImagingRecord {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], map: "imaging_records_appointment_fkey")

  visitId String?
  visit   Visit?  @relation(fields: [visitId], references: [id], map: "imaging_records_visit_fkey")

  dentistId String?
  dentist   Staff?  @relation(fields: [dentistId], references: [id], map: "imaging_records_dentist_fkey")

  // 🔥 NEW LINKS — now live relations so imaging is queryable from a chart
  // entry / procedure and a delete null-sets the link instead of orphaning it.
  procedureId  String?
  procedure    Procedure?  @relation("ProcedureImaging", fields: [procedureId], references: [id], onDelete: SetNull, map: "imaging_records_procedure_fkey")
  chartEntryId String?
  chartEntry   ChartEntry? @relation("ChartEntryImaging", fields: [chartEntryId], references: [id], onDelete: SetNull, map: "imaging_records_chart_entry_fkey")

  // 🔥 CLASSIFICATION
  type   ImagingType
  stage  ImagingStage?
  source ImagingSource?

  // 🔥 GROUPING
  groupId String?

  // FILE
  fileUrl      String
  thumbnailUrl String?
  storagePath  String?
  fileName     String
  fileSize     Int?
  mimeType     String?

  // CLINICAL
  toothNumbers Int[]
  notes        String?
  findings     String?
  annotations  Json?

  // META
  takenAt   DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ADVANCED
  comparisons  ImagingComparison[] @relation("BaseImage")
  comparedWith ImagingComparison[] @relation("CompareImage")

  procedureSessionId String?
  procedureSession   ProcedureSession? @relation(fields: [procedureSessionId], references: [id], onDelete: SetNull, map: "imaging_records_procedure_session_fkey")

  @@index([chartEntryId])
  @@index([procedureId])
  @@map("imaging_records")
}

model ImagingComparison {
  id             String        @id @default(cuid())
  baseImageId    String
  baseImage      ImagingRecord @relation("BaseImage", fields: [baseImageId], references: [id])
  compareImageId String
  compareImage   ImagingRecord @relation("CompareImage", fields: [compareImageId], references: [id])
  notes          String?
  createdAt      DateTime      @default(now())

  @@map("imaging_comparisons")
}

model DrugCategory {
