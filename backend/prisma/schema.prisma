// ── Double-entry General Ledger ───────────────────────────────────────────────
// NOTE: `LedgerAccount` (the Chart of Accounts) is deliberately DISTINCT from the
// `Account` model above. `Account` = physical cash/bank/mobile-money tills with a
// running balance. `LedgerAccount` = accounting buckets (A/R, Revenue, Patient
// Deposits, Tax Payable, …) against which balanced journal entries are posted.

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum NormalBalance {
  DEBIT // assets & expenses increase on the debit side
  CREDIT // liabilities, equity & income increase on the credit side
}

enum JournalStatus {
  POSTED // live, affects the books
  VOID // neutralised by a reversing entry (kept for audit, never deleted)
}

