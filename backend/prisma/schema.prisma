/// Every money movement — in or out — across all accounts
model CashFlowEntry {
  id        String  @id @default(cuid())
  entryCode String  @unique
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  direction CashFlowDirection
  source    CashFlowSource

  amount       Decimal @db.Decimal(10, 2) // Always in account's native currency
  currency     String  @default("UGX")
  exchangeRate Decimal @default(1) @db.Decimal(10, 4) // Rate used if cross-currency
  baseAmount   Decimal @default(0) @db.Decimal(10, 2) // Equivalent in UGX (base)

  // Running balance snapshot at time of entry
  balanceBefore Decimal @default(0) @db.Decimal(10, 2)
  balanceAfter  Decimal @default(0) @db.Decimal(10, 2)

  // Source document references (only one will be set per entry)
  receiptId String?
  receipt   Receipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  transferId String? // Links to AccountTransfer if source is TRANSFER_*
  transfer   AccountTransfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)

  // Daily balance this entry belongs to
  accountPeriodId String?
  accountPeriod   AccountPeriod? @relation(fields: [accountPeriodId], references: [id], onDelete: SetNull)

  description  String
  reference    String? // e.g. receipt number, PO number
  notes        String?
  recordedById String? // User who created this entry

  entryDate DateTime @default(now()) // Effective date of the transaction
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([direction])
  @@index([source])
  @@index([entryDate])
  @@index([receiptId])
  @@index([paymentId])
  @@map("cash_flow_entries")
}

/// Internal transfer between two accounts (e.g. cash to bank, bank to mobile money)
model AccountTransfer {
  id            String  @id @default(cuid())
  transferCode  String  @unique
  fromAccountId String
  fromAccount   Account @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccountId   String
  toAccount     Account @relation("TransferTo", fields: [toAccountId], references: [id])

  amount       Decimal @db.Decimal(10, 2) // Amount in fromAccount currency
  fromCurrency String  @default("UGX")
  toCurrency   String  @default("UGX")
  exchangeRate Decimal @default(1) @db.Decimal(10, 4) // fromCurrency → toCurrency
  toAmount     Decimal @db.Decimal(10, 2) // Amount credited to toAccount (after conversion)

  notes        String?
  reference    String?
  recordedById String?
  transferDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cashFlowEntries CashFlowEntry[] // Two entries: OUT from source, IN to destination

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([transferDate])
  @@map("account_transfers")
}

/// Tracks the opening and closing balance for each account per calendar day.
/// Enables daily cash reconciliation.
/// Tracks opening/closing balances for an account over a configurable accounting period.
/// Supports daily, weekly, monthly, or custom periods for flexible reconciliation.
model AccountPeriod {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // ── Period Definition ───────────────────────────────────────────────
  startDate   DateTime // Inclusive start of period
  endDate     DateTime // Inclusive end of period
  periodType  String // "DAILY" | "WEEKLY" | "MONTHLY" | "CUSTOM"
  periodLabel String? // Human-readable label, e.g. "May 2024"

  // ── Financial Summary ───────────────────────────────────────────────
  openingBalance Decimal  @default(0) @db.Decimal(10, 2)
  closingBalance Decimal? @db.Decimal(10, 2) // Calculated when period is closed
  totalIn        Decimal  @default(0) @db.Decimal(10, 2) // Sum of IN entries
  totalOut       Decimal  @default(0) @db.Decimal(10, 2) // Sum of OUT entries

  // ── Reconciliation Metadata ─────────────────────────────────────────
  status     AccountPeriodStatus @default(OPEN)
  notes      String?
  closedById String?
  closedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  entries CashFlowEntry[]

  // ── Indexes & Constraints ───────────────────────────────────────────
  @@unique([accountId, startDate, endDate]) // Prevent overlapping periods
  @@index([accountId, startDate])
  @@index([status])
  @@index([periodType])
  @@map("account_periods") // ← Updated table name
}

// ── Chart of Accounts ─────────────────────────────────────────────────────────
/// One accounting bucket (A/R, Treatment Revenue, Patient Deposits, …).
/// `isSystem` accounts are the canonical ones the posting engine relies on and
/// must never be deleted. `cashAccountId` optionally links a GL cash/bank bucket
/// to a physical `Account` so the two can be reconciled.
model LedgerAccount {
  id            String            @id @default(cuid())
  code          String            @unique // "1100" A/R, "4000" Revenue — user-editable
  // Stable internal handle for canonical accounts (e.g. "ACCOUNTS_RECEIVABLE").
  // The posting engine resolves system accounts by this, NOT by `code`, so the
  // code can be renamed freely without breaking automatic postings. Null for
  // user-created accounts.
  systemKey     String?           @unique
  name          String
  type          LedgerAccountType
  normalBalance NormalBalance
  description   String?
  isActive      Boolean           @default(true)
  isSystem      Boolean           @default(false) // canonical account — protected from deletion

  // Self-referencing hierarchy (sub-accounts roll up into a parent)
  parentId String?
  parent   LedgerAccount?  @relation("LedgerAccountTree", fields: [parentId], references: [id], onDelete: SetNull)
  children LedgerAccount[] @relation("LedgerAccountTree")

  // Optional reconciliation link to a physical cash/bank Account
  cashAccountId String?
  cashAccount   Account? @relation(fields: [cashAccountId], references: [id], onDelete: SetNull)

  lines             JournalLine[]
  expenseCategories ExpenseCategory[]

  // Procedures / categories that recognise revenue into this account.
  procedures          Procedure[]         @relation("ProcedureRevenueAccount")
  procedureCategories ProcedureCategory[] @relation("ProcedureCategoryRevenueAccount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([cashAccountId])
  @@map("ledger_accounts")
}

// ── Journal Entry (header) ────────────────────────────────────────────────────
/// A balanced set of debit/credit lines. Σdebit == Σcredit is enforced by the
/// posting service. Entries are NEVER edited or deleted; a void posts a separate
/// reversing entry and links the two via `reversesId` / `reversedBy`.
model JournalEntry {
  id          String   @id @default(cuid())
  entryNumber String   @unique // JE-26-0001
  date        DateTime @default(now())
  memo        String
  currency    String   @default("UGX") // functional/base currency the books are kept in

  // Source document (the business event that triggered the entry)
  sourceType String? // "INVOICE" | "RECEIPT" | "REFUND" | "EXPENSE" | "MANUAL" | "REVERSAL"
  sourceId   String?

  status JournalStatus @default(POSTED)

  // ── Immutable reversal linkage (1:1 self relation) ────────────────────────
  reversesId String?       @unique // set on the reversing entry → points at the original
  reverses   JournalEntry? @relation("JournalReversal", fields: [reversesId], references: [id])
  reversedBy JournalEntry? @relation("JournalReversal") // back-ref on the original

  // ── Audit ─────────────────────────────────────────────────────────────────
  patientId  String? // convenience tag when the entry concerns one patient
  postedById String?
  voidReason String?

  lines JournalLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceType, sourceId])
  @@index([date])
  @@index([status])
  @@index([patientId])
  @@map("journal_entries")
}

// ── Journal Line ──────────────────────────────────────────────────────────────
/// One side of a journal entry. Amounts are stored in the books' base currency;
/// the original transaction-currency figures are kept on `fxAmount` / `currency`
/// / `fxRate` for audit only. Exactly one of debit/credit is non-zero per line.
model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  accountId String
  account   LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  debit  Decimal @default(0) @db.Decimal(14, 2) // base currency
  credit Decimal @default(0) @db.Decimal(14, 2) // base currency

  // Original transaction-currency snapshot (audit only — does NOT affect balance)
  currency String?
  fxAmount Decimal? @db.Decimal(14, 2)
  fxRate   Decimal? @db.Decimal(14, 6)

  patientId String? // subledger tag (e.g. A/R per patient)
  memo      String?

  createdAt DateTime @default(now())

  @@index([journalEntryId])
  @@index([accountId])
  @@index([patientId])
  @@map("journal_lines")
}

model BillingService {
  id          String  @id @default(cuid())
  serviceCode String  @unique
  name        String
  description String?

  // ── Which ledger type this maps to ──────────────────────────────────
  type     LedgerEntryType        @default(SERVICE)
  category BillingServiceCategory @default(OTHER)

  // ── Pricing ──────────────────────────────────────────────────────────
  price        Decimal  @default(0) @db.Decimal(12, 2)
  currency     String   @default("UGX") // currency the price is defined in
  exchangeRate Decimal? @db.Decimal(10, 4) // optional pre-set rate to UGX

  // ── Optional tax that is automatically applied ───────────────────────
  defaultTaxAmount Decimal @default(0) @db.Decimal(12, 2)
  defaultTaxLabel  String? // e.g. "VAT 18%"

  // ── Price range guardrails (for overriding at add-time) ──────────────
  priceRangeMin Decimal? @db.Decimal(12, 2)
  priceRangeMax Decimal? @db.Decimal(12, 2)

  // ── Metadata ─────────────────────────────────────────────────────────
  isActive   Boolean @default(true)
  isFavorite Boolean @default(false) // pin to top in UI
  sortOrder  Int     @default(0)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([isActive])
  @@index([isFavorite])
  @@map("billing_services")
}

model FixedAsset {
  id          String         @id @default(cuid())
  assetCode   String         @unique // e.g. DA-001, IE-002
  name        String
  description String?
  category    AssetCategory
  status      AssetStatus    @default(ACTIVE)
  condition   AssetCondition @default(GOOD)

  // ── Acquisition ───────────────────────────────────────────────────────
  purchaseDate   DateTime
  purchaseCost   Decimal   @db.Decimal(14, 2)
  currency       String    @default("UGX")
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  invoiceNumber  String?
  warrantyExpiry DateTime?
  serialNumber   String?
  modelNumber    String?
  manufacturer   String?
  attachments    String[] // File URLs (invoice scans, photos, manuals)

  // ── Location (current) ────────────────────────────────────────────────
  locationId        String?
  location          Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  assignedToStaffId String?
  assignedToStaff   Staff?    @relation("AssetAssignedTo", fields: [assignedToStaffId], references: [id], onDelete: SetNull)
  assignedAt        DateTime?

  // ── Depreciation config ───────────────────────────────────────────────
  depreciationMethod    DepreciationMethod @default(STRAIGHT_LINE)
  usefulLifeYears       Int? // For straight-line
  salvageValue          Decimal?           @db.Decimal(14, 2)
  depreciationRate      Decimal?           @db.Decimal(6, 2) // For declining balance (e.g. 0.2 = 20%)
  depreciationStartDate DateTime?
  isDepreciable         Boolean            @default(true)

  // ── Running values (updated by depreciation job / manual entry) ───────
  currentBookValue        Decimal   @default(0) @db.Decimal(14, 2)
  accumulatedDepreciation Decimal   @default(0) @db.Decimal(14, 2)
  lastDepreciationDate    DateTime?

  // ── Disposal (populated when disposed) ───────────────────────────────
  disposedAt     DateTime?
  disposalMethod DisposalMethod?
  disposalValue  Decimal?        @db.Decimal(14, 2)
  disposalNotes  String?

  notes String?
  tags  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  depreciationEntries AssetDepreciationEntry[]
  maintenanceRecords  AssetMaintenance[]
  movementHistory     AssetMovement[]
  auditTrail          AssetAuditTrail[]

  @@index([category])
  @@index([status])
  @@index([locationId])
  @@index([supplierId])
  @@index([purchaseDate])
  @@map("fixed_assets")
}

// ── Depreciation ledger ──────────────────────────────────────────────────────

model AssetDepreciationEntry {
  id      String     @id @default(cuid())
  assetId String
  asset   FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  periodStart        DateTime // First day of period
  periodEnd          DateTime // Last day of period (usually last day of month/year)
  depreciationAmount Decimal            @db.Decimal(14, 2)
  bookValueBefore    Decimal            @db.Decimal(14, 2)
  bookValueAfter     Decimal            @db.Decimal(14, 2)
  method             DepreciationMethod
  notes              String?
  postedById         String? // User who posted this entry
  createdAt          DateTime           @default(now())

  @@index([assetId, periodStart])
  @@map("asset_depreciation_entries")
}

// ── Maintenance records ──────────────────────────────────────────────────────

model AssetMaintenance {
  id              String     @id @default(cuid())
  maintenanceCode String     @unique
  assetId         String
  asset           FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  type        MaintenanceType
  status      MaintenanceStatus @default(SCHEDULED)
  title       String
  description String?

  scheduledDate DateTime
  completedDate DateTime?
  nextDueDate   DateTime? // Auto-scheduled next maintenance

  // ── Cost ─────────────────────────────────────────────────────────────
  estimatedCost   Decimal? @db.Decimal(12, 2)
  actualCost      Decimal? @db.Decimal(12, 2)
  serviceProvider String? // External vendor name
  technicianName  String?

  // ── Outcome ───────────────────────────────────────────────────────────
  conditionBefore AssetCondition?
  conditionAfter  AssetCondition?
  findings        String?
  partsReplaced   String?
  attachments     String[]

  performedById String? // Internal staff
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([scheduledDate])
  @@map("asset_maintenance")
}

// ── Movement / transfer log ───────────────────────────────────────────────────

model AssetMovement {
  id      String     @id @default(cuid())
  assetId String
  asset   FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  type           AssetMovementType
  fromLocationId String?
  toLocationId   String?
  fromStaffId    String?
  toStaffId      String?

  reason             String?
  expectedReturnDate DateTime? // For loans
  actualReturnDate   DateTime?
  authorizedById     String?
  movedAt            DateTime  @default(now())
  createdAt          DateTime  @default(now())

  @@index([assetId])
  @@index([movedAt])
  @@map("asset_movements")
}

// ── Audit trail ───────────────────────────────────────────────────────────────

model AssetAuditTrail {
  id           String     @id @default(cuid())
  assetId      String
  asset        FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  action       String // e.g. CREATED, UPDATED, DISPOSED, MAINTENANCE_ADDED
  fieldChanged String?
  oldValue     String?
  newValue     String?
  changedById  String?
  notes        String?
  createdAt    DateTime   @default(now())

  @@index([assetId])
  @@index([createdAt])
  @@map("asset_audit_trail")
}

model StockTransfer {
  id           String @id @default(cuid())
  transferCode String @unique // e.g., TRF-2024-0001

  fromLocationId String
  fromLocation   Location @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocationId   String
  toLocation     Location @relation("TransferTo", fields: [toLocationId], references: [id])

  status        StockTransferStatus @default(DRAFT)
  transferDate  DateTime            @default(now())
  completedAt   DateTime?
  notes         String?
  internalNotes String?

  performedById String?
  performedBy   User?   @relation(fields: [performedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         StockTransferItem[]
  ledgerEntries InventoryLedger[]   @relation("TransferLedgerEntries")

  @@index([status])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([transferDate])
  @@map("stock_transfers")
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  itemName        String
  unit            String
  uom             UnitOfMeasure @default(PIECES)

  quantityRequested   Float
  quantityTransferred Float @default(0) // May be partial

  // Batch selection for batch-tracked items
  batchNumber          String? // Manual selection
  expiryDate           DateTime? // For reference
  distributionStrategy String? // "FEFO" | "FIFO" | "MANUAL"

  unitCost Decimal @default(0) @db.Decimal(10, 2)
  notes    String?

  createdAt DateTime @default(now())

  @@index([transferId])
  @@index([inventoryItemId])
  @@map("stock_transfer_items")
}

model Condition {
  id          String  @id @default(cuid())
  // UN-1: enforced unique in the DB (Postgres unique index) so a racing
  // concurrent create cannot insert two catalog rows with the same name.
  // The service-level findFirst duplicate check stays as a friendlier 400
  // for the common path; the constraint is the hard guarantee.
  name        String  @unique
  description String?

  // ── Code triplet (Dentrix shows all three) ────────────────────────────
  snodentCode  String? // SNODENT code   e.g. "100227D"
  snomedCtCode String? // SNOMED CT code e.g. "109600001"
  icd10Code    String? // ICD-10 code    e.g. "K02.9"
  icd10Term    String? // ICD-10 long terminology

  // ── NEW: drives chart rendering, no magic strings in the frontend ─────
  chartPresenceEffect ChartPresenceEffect @default(NONE)

  // L2: whether a completed treatment may AUTO-resolve a patient condition of
  // this type. FALSE for long-term / monitoring / presence-affecting findings
  // (bruxism, chronic periodontitis, attrition, missing tooth…) that a single
  // procedure does not "cure". Replaces the hard-coded name-match list in
  // ConditionsService.evaluateConditionStatus, which broke if a clinic renamed
  // a condition. Presence-affecting effects are still also guarded by
  // chartPresenceEffect != NONE.
  autoResolves Boolean @default(true)

  codingSystem ConditionCodingSystem @default(ICD_10)
  category     ConditionCategory     @default(OTHER)

  // ── Clinical constraints ──────────────────────────────────────────────
  affectedArea    String? // "Tooth" | "Root" | "Arch" | "Quadrant" | "Soft Tissue"
  isToothSpecific Boolean            @default(true)
  requiresSurface Boolean            @default(false)
  defaultSeverity ConditionSeverity?

  // ── Catalog control ───────────────────────────────────────────────────
  isActive    Boolean @default(true)
  isSystem    Boolean @default(true) // true = shipped default; false = clinic-created
  isFavourite Boolean @default(false)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientConditions PatientCondition[]
  chartEntries      ChartEntry[]

  @@index([isActive])
  @@index([isFavourite])
  @@index([category])
  @@index([icd10Code])
  @@map("conditions")
}

model PatientCondition {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  visitId String?
  visit   Visit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)

  conditionId String
  condition   Condition @relation(fields: [conditionId], references: [id], onDelete: Restrict)

  toothNotation ToothNotation @default(FDI) // ← NEW

  // E1: optimistic-lock token. Bumped on every mutation. A guarded update
  // (updateMany where { id, version }) detects a concurrent edit (lost update)
  // and the service raises 409 when the caller supplied the version it read.
  version Int @default(0)

  // ── Clinical specifics ────────────────────────────────────────────────
  toothNumber Int?
  surfaces    ToothSurface[]
  severity    ConditionSeverity?
  status      PatientConditionStatus @default(ACTIVE)
  notes       String?

  diagnosedAt DateTime @default(now())

  // ── Condition lifecycle resolution ────────────────────────────────────
  resolvedAt              DateTime?
  resolvedByProcedureId   String?
  resolvedByProcedure     TreatmentProcedure? @relation("ResolvedByProcedure", fields: [resolvedByProcedureId], references: [id], onDelete: SetNull)

  // ── Optional backlink to a treatment procedure ────────────────────────
  relatedProcedureId String?
  relatedProcedure   Procedure? @relation(fields: [relatedProcedureId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Audit actors (User.id) ────────────────────────────────────────────
  // Denormalised so the chart can show "who recorded / last edited" at a
  // glance. Full diff history lives in AuditLog. Stored as plain String?
  // (no strict FK) so a user delete never blocks a clinical-record write.
  createdById    String?
  updatedById    String?
  lastEditReason String?

  // ── Soft delete (clinical records are never hard-deleted) ────────────
  deletedAt     DateTime?
  deletedById   String?
  deletedReason String?

  // Back-link to chart entry (one-to-one, optional)
  chartEntries            ChartEntry[]
  conditionProcedureLinks ConditionProcedureLink[]
  progressReportLinks     ProgressReportCondition[]

  diagnosedBy String? // keep as free-text fallback
  providerId  String?
  provider    Staff?  @relation("PatientConditionProvider", fields: [providerId], references: [id], onDelete: SetNull)

  @@index([patientId, status])
  @@index([visitId])
  @@index([conditionId])
  @@index([deletedAt])
  @@index([resolvedByProcedureId])
  @@map("patient_conditions")
}

model ConditionProcedureLink {
  id                   String             @id @default(cuid())
  patientConditionId   String
  patientCondition     PatientCondition   @relation(fields: [patientConditionId], references: [id], onDelete: Cascade)
  treatmentProcedureId String
  treatmentProcedure   TreatmentProcedure @relation(fields: [treatmentProcedureId], references: [id], onDelete: Cascade)
  createdAt            DateTime           @default(now())

  // ── Audit: who linked it, when ───────────────────────────────────────────
  linkedAt   DateTime @default(now())
  linkedById String?

  // ── Snapshot of the condition AT LINK TIME ───────────────────────────────
  // Frozen so clinical history is preserved even if the underlying
  // PatientCondition / Condition is later edited or its status changes.
  conditionNameAtLink   String?
  conditionCodeAtLink   String?
  conditionStatusAtLink String?

  // ── Soft delete (audit-preserving unlink) ────────────────────────────────
  deletedAt     DateTime?
  unlinkedById  String?
  deletedReason String?

  // Uniqueness on ACTIVE links is enforced by a PARTIAL UNIQUE INDEX
  // (Prisma's @@unique cannot express partial predicates). Canonical source:
  // migration 20260710000001_partial_unique_indexes_and_checks. The boot hook
  // in PrismaService.onModuleInit re-applies it idempotently as a safety net
  // for dev databases created with `prisma db push`. A condition can be
  // re-linked to the same procedure after the prior link is soft-deleted, but
  // never double-linked while both links have deletedAt IS NULL.
  @@index([treatmentProcedureId])
  @@index([patientConditionId])
  @@index([deletedAt])
  @@map("condition_procedure_links")
}

model ProgressReportProcedure {
  id                 String           @id @default(cuid())
  reportId           String
  report             ProgressReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  procedureSessionId String
  procedureSession   ProcedureSession @relation(fields: [procedureSessionId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@unique([reportId, procedureSessionId])
  @@index([reportId])
  @@index([procedureSessionId])
  @@map("progress_report_procedures")
}

model ProgressReportCondition {
  id                 String           @id @default(cuid())
  reportId           String
  report             ProgressReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  patientConditionId String
  patientCondition   PatientCondition @relation(fields: [patientConditionId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@unique([reportId, patientConditionId])
  @@index([reportId])
  @@index([patientConditionId])
  @@map("progress_report_conditions")
}

// ── New audit table ───────────────────────────────────────────────────────────
model ProcedureSessionEdit {
  id       String @id @default(cuid())
  editCode String @unique

  sessionId String
  session   ProcedureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Surface diff
  surfacesBefore  String[]
  surfacesAfter   String[]
  surfacesAdded   String[]
  surfacesRemoved String[]

  // Other field diffs
  notesBefore String?
  notesAfter  String?
  phaseBefore String?
  phaseAfter  String?

  reason       String?
  editedById   String?
  editedByName String?
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@map("procedure_session_edits")
}

model StockOut {
  id         String   @id @default(cuid())
  outCode    String   @unique // e.g. SO-2025-0001
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  reason        String? // free-text: "Clinic use", "Training", etc.
  category      StockOutCategory @default(GENERAL_USE)
  notes         String?
  performedById String? // who issued the stock

  totalValue Decimal @default(0) @db.Decimal(10, 2) // Σ (qty × unitCost)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         StockOutItem[]
  ledgerEntries InventoryLedger[]

  @@index([locationId])
  @@index([category])
  @@index([createdAt])
  @@map("stock_outs")
}

model StockOutItem {
  id         String   @id @default(cuid())
  stockOutId String
  stockOut   StockOut @relation(fields: [stockOutId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  itemName  String
  unit      String
  quantity  Float
  unitCost  Decimal @default(0) @db.Decimal(10, 2)
  totalCost Decimal @default(0) @db.Decimal(10, 2)

  // Batch context (what was actually deducted — filled after processing)
  batchNumber          String?
  distributionStrategy String? @default("FEFO") // FEFO | FIFO | MANUAL

  notes     String?
  createdAt DateTime @default(now())

  @@index([stockOutId])
  @@index([inventoryItemId])
  @@map("stock_out_items")
}

model Notification {
  id String @id @default(cuid())

  // ── Targeting ───────────────────────────────────────────────────────
  userId     String? // Specific user (null = broadcast)
  user       User?     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  targetRole UserRole? // Role-based targeting (null = all roles)

  // ── Content ─────────────────────────────────────────────────────────
  title    String
  message  String
  type     NotificationType     @default(INFO)
  category NotificationCategory @default(SYSTEM)
  priority NotificationPriority @default(MEDIUM)

  // ── State ───────────────────────────────────────────────────────────
  isRead Boolean   @default(false)
  readAt DateTime?

  // ── Navigation & context ────────────────────────────────────────────
  actionUrl  String? // e.g. "/appointments/clu123abc"
  entityType String? // e.g. "APPOINTMENT", "INVOICE", "VISIT"
  entityId   String? // FK to the source entity

  // ── Event traceability ──────────────────────────────────────────────
  eventType String? // e.g. "APPOINTMENT_STATUS_CHANGED"
  eventData Json? // Snapshot of event payload for audit

  // ── Actor (who triggered this) ──────────────────────────────────────
  actorId String? // User who caused the event
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([targetRole, isRead])
  @@index([category])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("notifications_v2")
}

/// Stores per-user notification preferences (opt-out model).
model NotificationPreference {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("NotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  category  NotificationCategory
  enabled   Boolean              @default(true) // false = user opted out of this category
  showToast Boolean              @default(true) // Show toast/popup for this category
  playSound Boolean              @default(false) // Play notification sound

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
  @@map("notification_preferences")
}

model TreatmentConsumption {
  id              String   @id @default(cuid())
  consumptionCode String   @unique
  treatmentPlanId String?
  treatmentPlan   TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)
  patientId       String?
  patient         Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  itemType        String   // "DRUG" | "INVENTORY"
  itemId          String
  itemName        String
  quantity        Float
  unitCost        Decimal  @db.Decimal(10, 2)
  totalCost       Decimal  @db.Decimal(10, 2)
  notes           String?
  performedById   String?
  performedBy     User?    @relation(fields: [performedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([treatmentPlanId])
  @@index([patientId])
  @@index([itemType, itemId])
  @@map("treatment_consumptions")
}
